{
  "compilerOptions": {
    "target": "ES2018",
    "module": "commonjs",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "lib": ["es2015"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true
  },
  "exclude": ["remotion.config.ts", "src/components/captions/_archive/**", "src/compositions/KaraokeHighlightDemo.tsx", "src/compositions/WeightShiftDemo.tsx", "src/compositions/BounceKineticDemo.tsx", "src/compositions/CRTHighlightDemo.tsx", "src/compositions/GradientHighlightDemo.tsx"]
}
